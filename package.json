{
  "name": "mesh",
  "version": "3.8.0",
  "description": "A peer-to-peer git daemon.",
  "type": "module",
  "private": true,
  "bin": {
    "mesh": "./src/main.ts"
  },
  "scripts": {
    "start": "bun src/main.ts start",
    "dev": "bun --watch src/main.ts start",
    "typecheck": "tsc --noEmit",
    "build": "bun build src/main.ts --compile --outfile mesh",
    "package": "bun scripts/package.ts",
    "release": "bun scripts/release.ts",
    "release:fix": "bun scripts/release.ts fix",
    "release:breaking": "bun scripts/release.ts breaking"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
